#!/usr/bin/env bash
# Mock claude CLI. Records argv to $MOCK_CLAUDE_LOG.
# Env: MOCK_CLAUDE_FAIL=1 -> exit 1; MOCK_CLAUDE_OUTPUT -> stdout text.
if [ -n "${MOCK_CLAUDE_LOG:-}" ]; then
    printf '%s\n' "$*" >> "$MOCK_CLAUDE_LOG"
fi
if [ "${MOCK_CLAUDE_FAIL:-0}" = "1" ]; then
    echo "mock failure" >&2
    exit 1
fi
printf '%s\n' "${MOCK_CLAUDE_OUTPUT:-ok}"
