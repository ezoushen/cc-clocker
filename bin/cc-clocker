#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

_self="$(readlink "$0" 2>/dev/null || true)"
[ -n "$_self" ] || _self="$0"
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$PROJECT_ROOT/lib"

: "${CC_CLOCKER_HOME:=$HOME/.local/share/cc-clocker}"
: "${CC_CLOCKER_STATE:=$HOME/.local/state/cc-clocker}"
PID_FILE="$CC_CLOCKER_STATE/pid"

# Bootstrap PATH so launchd / systemd / cron sessions (which start with a
# minimal PATH) can still find `claude`, `jq`, and friends. We append the
# common user / homebrew bin locations so the inherited PATH still wins.
for _extra in "$HOME/.local/bin" /opt/homebrew/bin /usr/local/bin; do
    case ":$PATH:" in
        *":$_extra:"*) ;;
        *) [ -d "$_extra" ] && PATH="$PATH:$_extra" ;;
    esac
done
unset _extra
export PATH

# shellcheck source=lib/log.sh
source "$LIB_DIR/log.sh"
# shellcheck source=lib/db.sh
source "$LIB_DIR/db.sh"
# shellcheck source=lib/window.sh
source "$LIB_DIR/window.sh"
# shellcheck source=lib/ping.sh
source "$LIB_DIR/ping.sh"
# shellcheck source=lib/schedule.sh
source "$LIB_DIR/schedule.sh"

usage() {
    cat <<EOF
usage: cc-clocker <command> [args]

Commands:
  run                          Start the clocker daemon (foreground)
  status                       Show last ping and next scheduled fire
  tick                         Fire one ping immediately
  log [N]                      Show last N pings (default 20)
  init                         Initialize DB + state dirs
  stop                         Stop running daemon
  doctor                       Check dependencies and auth
  set-anchor 5h|7d <ISO>       Save a known reset point for the current account
                               (drift-free projection forever)
  statusline-tee [cmd args..]  Wrap a real statusline command. Captures
                               rate_limits + orgId from stdin, writes to
                               \$CC_CLOCKER_CACHE_FILE, then forwards stdin
                               to the wrapped command unchanged.
EOF
}

cmd_init() {
    mkdir -p "$CC_CLOCKER_HOME" "$CC_CLOCKER_STATE"
    db_init
    log_info "initialized $CC_CLOCKER_HOME"
}

cmd_set_anchor() {
    local kind="${1:-}" iso="${2:-}"
    case "$kind" in
        5h|7d) ;;
        *) echo "usage: cc-clocker set-anchor 5h|7d <ISO8601 UTC>" >&2; return 1 ;;
    esac
    if ! [[ "$iso" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?Z$ ]]; then
        echo "anchor must be ISO8601 UTC (e.g. 2026-04-27T16:20:00Z)" >&2
        return 1
    fi
    cmd_init >/dev/null 2>&1 || true
    local org_id
    org_id="$(_current_org_id)"
    if [ -z "$org_id" ]; then
        echo "could not resolve orgId via 'claude auth status'; are you logged in?" >&2
        return 1
    fi
    db_set_anchor "$org_id" "$kind" "$iso"
    echo "saved $kind anchor for org $org_id: $iso ($(fmt_local "$iso"))"
}

cmd_statusline_tee() {
    # Buffer stdin once; we need to consume it for parsing AND forward it to
    # the wrapped command.
    local input
    input="$(cat)"

    # Best-effort: extract rate_limits + orgId, write cache. Failures are
    # silent — statusline must never break because the cache write failed.
    {
        local cache_file="${CC_CLOCKER_CACHE_FILE:-$HOME/.cc-clocker/rate-limits.json}"
        local cache_dir
        cache_dir="$(dirname "$cache_file")"
        mkdir -p "$cache_dir" 2>/dev/null

        local org_id r5 r7
        org_id="$(_current_org_id)"
        r5="$(printf '%s' "$input" | jq -r 'try .rate_limits.five_hour.resets_at // empty' 2>/dev/null)"
        r7="$(printf '%s' "$input" | jq -r 'try .rate_limits.seven_day.resets_at // empty' 2>/dev/null)"

        if [ -n "$org_id" ] && { [ -n "$r5" ] || [ -n "$r7" ]; }; then
            local tmp="${cache_file}.tmp.$$"
            jq -n \
                --arg org "$org_id" \
                --argjson r5 "${r5:-null}" \
                --argjson r7 "${r7:-null}" \
                '{org_id: $org, five_hour_resets_at: $r5, seven_day_resets_at: $r7, captured_at: now}' \
                > "$tmp" 2>/dev/null \
                && mv -f "$tmp" "$cache_file" 2>/dev/null
            rm -f "$tmp" 2>/dev/null
        fi
    } 2>/dev/null

    # Forward stdin to wrapped command (or echo it through if no command).
    if [ "$#" -gt 0 ]; then
        printf '%s' "$input" | "$@"
    else
        printf '%s' "$input"
    fi
}

cmd_tick() {
    cmd_init >/dev/null 2>&1 || true
    fire_now
}

cmd_log() {
    local n="${1:-20}"
    cmd_init >/dev/null 2>&1 || true
    printf 'ts\treset_detected\twhich\tresponse_chars\tok\n'
    # DB stores UTC; convert ts and reset_detected to local TZ for display.
    local ts reset_d which chars ok
    while IFS=$'\t' read -r ts reset_d which chars ok; do
        printf '%s\t%s\t%s\t%s\t%s\n' \
            "$(fmt_local "$ts")" \
            "$(fmt_local "$reset_d")" \
            "$which" "$chars" "$ok"
    done < <(db_recent_pings "$n")
}

cmd_status() {
    cmd_init >/dev/null 2>&1 || true
    local last
    last="$(db_last_ping)"
    if [ -z "$last" ]; then
        echo "no pings recorded yet (never run)"
    else
        local last_ts last_reset last_which
        last_ts="$(printf '%s' "$last" | cut -f1)"
        last_reset="$(printf '%s' "$last" | cut -f2)"
        last_which="$(printf '%s' "$last" | cut -f3)"
        echo "last ping:           $(fmt_local "$last_ts") ($last_which window, reset $(fmt_local "$last_reset"))"
    fi

    local detected
    if detected="$(detect_window 2>/dev/null)"; then
        local next which r5 r7 fire_at
        next="$(printf '%s' "$detected" | cut -f1)"
        which="$(printf '%s' "$detected" | cut -f2)"
        r5="$(printf '%s' "$detected" | cut -f3)"
        r7="$(printf '%s' "$detected" | cut -f4)"
        fire_at="$(next_fire_time "$next")"
        if [ -n "$r5" ]; then echo "5h reset:            $(fmt_local "$r5")"; else echo "5h reset:            inactive"; fi
        if [ -n "$r7" ]; then echo "7d reset:            $(fmt_local "$r7")"; else echo "7d reset:            inactive"; fi
        echo "next fire:           $(fmt_local "$fire_at")  (window=$which)"
    else
        echo "5h reset:            inactive"
        echo "7d reset:            inactive"
        echo "next fire:           none — no active window"
    fi

    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "daemon:              running (pid $pid)"
        else
            echo "daemon:              stale pid file (pid $pid not alive)"
        fi
    else
        echo "daemon:              not running"
    fi
}

cmd_stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "not running"
        return 0
    fi
    local pid
    pid="$(cat "$PID_FILE")"
    if ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$PID_FILE"
        echo "not running (cleared stale pid)"
        return 0
    fi
    kill -TERM "$pid"
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        i=$((i+1))
        [ "$i" -ge 50 ] && break
        sleep 0.1 2>/dev/null || sleep 1
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid"
    fi
    rm -f "$PID_FILE"
    echo "stopped"
}

cmd_run() {
    cmd_init >/dev/null 2>&1 || true
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        log_error "already running (pid $(cat "$PID_FILE"))"
        exit 1
    fi
    echo $$ > "$PID_FILE"
    trap 'rm -f "$PID_FILE"; exit 0' EXIT INT TERM
    log_info "cc-clocker $VERSION starting (pid $$)"
    run_loop
}

cmd_doctor() {
    local rc=0
    echo "checking dependencies..."
    for tool in claude sqlite3 jq; do
        if command -v "$tool" >/dev/null 2>&1; then
            echo "  $tool: $(command -v "$tool")"
        else
            echo "  $tool: NOT FOUND"
            rc=1
        fi
    done

    echo "checking ~/.claude/projects access..."
    : "${CC_CLAUDE_HOME:=$HOME/.claude}"
    if [ -d "$CC_CLAUDE_HOME/projects" ]; then
        echo "  ok: $CC_CLAUDE_HOME/projects"
    else
        echo "  missing: $CC_CLAUDE_HOME/projects (run claude at least once)"
        rc=1
    fi

    echo "checking window detection..."
    local detected
    if detected="$(detect_window 2>/dev/null)"; then
        echo "  active: $(printf '%s' "$detected" | cut -f2) reset $(fmt_local "$(printf '%s' "$detected" | cut -f1)")"
    else
        echo "  no active window (run a real claude session to validate detection)"
    fi

    echo "checking statusline rate-limits cache..."
    local cache_file="${CC_CLOCKER_CACHE_FILE:-$HOME/.cc-clocker/rate-limits.json}"
    if [ -f "$cache_file" ]; then
        local cached_org cached_at
        cached_org="$(jq -r 'try .org_id // empty' "$cache_file" 2>/dev/null)"
        cached_at="$(jq -r 'try .captured_at // empty' "$cache_file" 2>/dev/null)"
        # captured_at is a unix epoch (float). Convert to local ISO for display.
        local cached_at_local=""
        if [[ "$cached_at" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
            cached_at_local="$(sqlite3 :memory: "SELECT strftime('%Y-%m-%dT%H:%M:%S', ${cached_at}, 'unixepoch', 'localtime');")$(date '+%z')"
        fi
        echo "  found: $cache_file (org=$cached_org, captured_at=${cached_at_local:-$cached_at})"
    else
        echo "  not found at $cache_file"
        echo "  to enable drift-free, account-aware reset detection:"
        echo "    1. Edit ~/.claude/settings.json statusLine.command to:"
        echo "         $(command -v cc-clocker || echo cc-clocker) statusline-tee <your existing statusline command>"
        echo "    2. Open any interactive claude session — the cache will populate."
    fi

    echo "checking user hooks (will fire on every ping)..."
    local hook_files=(~/.claude/settings.json ~/.claude/hooks.json)
    local hook_count=0
    for hf in "${hook_files[@]}"; do
        [ -f "$hf" ] || continue
        local n
        n="$(jq -r '.hooks // {} | to_entries | map(.value | length) | add // 0' "$hf" 2>/dev/null)"
        [ -n "$n" ] && [ "$n" != "null" ] && hook_count=$((hook_count + n))
    done
    if [ "$hook_count" -gt 0 ]; then
        echo "  found $hook_count user-level hook(s) — they WILL fire on every ping"
        echo "  gate them in their command body with:"
        echo "      [ -n \"\$CC_CLOCKER_PING\" ] && exit 0"
    else
        echo "  no user-level hooks found"
    fi

    echo "checking claude auth (synthetic ping)..."
    if CC_CLOCKER_PING=1 claude -p "ok" \
        --no-session-persistence --tools "" \
        --strict-mcp-config --mcp-config '{"mcpServers":{}}' \
        --model claude-haiku-4-5-20251001 \
        --output-format text >/dev/null 2>&1; then
        echo "  ok"
    else
        echo "  FAIL — check 'claude auth' status"
        rc=1
    fi

    return "$rc"
}

main() {
    if [ "$#" -eq 0 ]; then
        usage
        exit 1
    fi
    local cmd="$1"; shift || true
    case "$cmd" in
        --version|-v) echo "$VERSION" ;;
        --help|-h)    usage ;;
        run)             cmd_run "$@" ;;
        status)          cmd_status "$@" ;;
        tick)            cmd_tick "$@" ;;
        log)             cmd_log "$@" ;;
        init)            cmd_init "$@" ;;
        stop)            cmd_stop "$@" ;;
        doctor)          cmd_doctor "$@" ;;
        set-anchor)      cmd_set_anchor "$@" ;;
        statusline-tee)  cmd_statusline_tee "$@" ;;
        *)            echo "unknown command: $cmd" >&2; usage; exit 1 ;;
    esac
}

main "$@"
