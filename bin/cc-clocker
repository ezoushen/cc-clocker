#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

usage() {
    cat <<EOF
usage: cc-clocker <command> [args]

Commands:
  run       Start the clocker daemon (foreground)
  status    Show last ping and next scheduled fire
  tick      Fire one ping immediately
  log [N]   Show last N pings (default 20)
  init      Initialize DB + state dirs
  stop      Stop running daemon
  doctor    Check dependencies and auth
EOF
}

main() {
    if [ "$#" -eq 0 ]; then
        usage
        exit 1
    fi
    case "$1" in
        --version|-v) echo "$VERSION" ;;
        --help|-h) usage ;;
        *) echo "unknown command: $1" >&2; usage; exit 1 ;;
    esac
}

main "$@"
